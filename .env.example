# ── Public (safe to expose) ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://pilk.ai
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Lead storage (optional — app runs without it) ────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Transactional email (optional) ───────────────────────
RESEND_API_KEY=
LEADS_NOTIFICATION_EMAIL=
LEADS_FROM_EMAIL=

# ── CRM + spam + rate limiting (optional) ────────────────
CRM_WEBHOOK_URL=
TURNSTILE_SECRET_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare BINDINGS (not plain env vars) ─────────────
# Configure these in the Cloudflare Pages dashboard, not in this file:
#   R2 bucket binding name: PROJECT_UPLOADS  (private bucket for brief uploads)
# Settings → Functions → R2 bucket bindings → add binding "PROJECT_UPLOADS"
# (Text-only briefs work without it; uploads require it.)
